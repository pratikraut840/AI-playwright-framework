{
  "name": "ai-framework-playwright",
  "version": "1.0.0",
  "description": "Playwright + Cucumber BDD automation framework for OrangeHRM (UI + API)",
  "author": "pratik-raut",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "test": "npm run test:bdd",
    "test:all": "npm run test:bdd && npm run test:tdd && npm run test:api",
    "test:bdd": "npx cucumber-js --config cucumber.mjs",
    "test:bdd:headed": "cross-env HEADLESS=false npx cucumber-js --config cucumber.mjs",
    "test:bdd:smoke": "npx cucumber-js --config cucumber.mjs --tags @smoke",
    "test:bdd:progress": "npx cucumber-js --config cucumber.mjs --profile progress",
    "test:bdd:regression": "npx cucumber-js --config cucumber.mjs --tags @regression",
    "test:bdd:chromium": "cross-env BROWSER=chromium npx cucumber-js --config cucumber.mjs",
    "test:bdd:firefox": "cross-env BROWSER=firefox npx cucumber-js --config cucumber.mjs",
    "test:bdd:webkit": "cross-env BROWSER=webkit npx cucumber-js --config cucumber.mjs",

    "test:smoke": "npm run test:bdd:smoke",
    "test:regression": "npm run test:bdd:regression",
    "test:headed": "npm run test:bdd:headed",
    
    "report:bdd": "ts-node src/ui/helpers/reports/report.ts",
    "convert:bdd:junit": "node ./convert-cucumber-to-junit.mjs",
    "report:bdd:junit": "npm run convert:bdd:junit && node src/ui/helpers/scripts/view-junit.mjs test-results/test-results-bdd/junit-report/junit-report-bdd.xml test-results/test-results-bdd/junit-report/junit-viewer-tdd.html \"OrangeHRM BDD JUnit\"",
    "report:bdd:all": "npm run report:bdd && npm run convert:bdd:junit && npm run report:bdd:junit",
    
    "test:tdd": "playwright test",
    "test:tdd:headed": "cross-env HEADLESS=false playwright test --headed",
    "test:tdd:ui": "playwright test --ui",
    "test:tdd:smoke": "playwright test -g \"@smoke\" --project=chromium --project=chromium-authorized",
    "test:tdd:regression": "playwright test --project=chromium --project=chromium-authorized",
    "test:tdd:chromium": "playwright test --project=chromium --project=chromium-authorized",
    "test:tdd:firefox": "playwright test --project=firefox --project=firefox-authorized",
    "test:tdd:webkit": "playwright test --project=webkit --project=webkit-authorized",
    "test:tdd:mobile": "playwright test --project=mobile-chromium --project=mobile-chromium-authorized --project=mobile-webkit --project=mobile-webkit-authorized",
    "test:tdd:junit": "cross-env CI=true playwright test",
    "test:tdd:log": "node src/ui/helpers/scripts/run-tdd-with-log.mjs",
    
    "report:tdd": "node src/ui/helpers/scripts/show-tdd-report.mjs",
    "report:tdd:junit": "node src/ui/helpers/scripts/view-junit.mjs playwright-report/playwright-report-tdd/junit-report-tdd/junit.xml playwright-report/playwright-report-tdd/junit-report-tdd/junit-viewer-tdd.html \"OrangeHRM TDD JUnit\"",
    "report:tdd:all": "node src/ui/helpers/scripts/report-all.mjs",
    
    "allure:generate": "ts-node src/ui/helpers/reports/report.ts allure:generate",
    "allure:serve": "ts-node src/ui/helpers/reports/report.ts allure:serve",
    "allure:all": "npm run allure:generate && npm run allure:serve",
    "allure:open": "node src/ui/helpers/scripts/allure-open.mjs",
    
    "test:api": "node src/api/scripts/run-api-tests.mjs",
    "test:api:smoke": "playwright test --config=playwright.api.config.ts -g \"@smoke\"",
    "test:api:regression": "playwright test --config=playwright.api.config.ts -g \"@regression\"",
    "test:api:ui": "playwright test --config=playwright.api.config.ts --ui",
    "test:api:junit": "cross-env CI=true playwright test --config=playwright.api.config.ts",
    
    "report:api": "node src/ui/helpers/scripts/view-junit.mjs test-results/test-results-api/junit-report-api/junit.xml test-results/test-results-api/junit-report-api/junit-viewer-api.html \"Restful-Booker API JUnit\"",
    "report:api:generate": "node src/ui/helpers/scripts/view-junit.mjs test-results/test-results-api/junit-report-api/junit.xml test-results/test-results-api/junit-report-api/junit-viewer-api.html \"Restful-Booker API JUnit\" --generate-only",
    "report:api:all": "npm run test:api && npm run report:api && npm run report:api:generate",
    "allure:api:generate": "ts-node src/ui/helpers/reports/report.ts allure:api:generate",
    "allure:api:serve": "ts-node src/ui/helpers/reports/report.ts allure:api:serve",
    "allure:api:all": "npm run allure:api:generate && npm run allure:api:serve",
    
    "tsc": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "ajv": "^8.18.0",
    "allure-commandline": "^2.36.0",
    "allure-cucumberjs": "^3.4.5",
    "allure-playwright": "^3.4.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^10.0.1",
    "multiple-cucumber-html-reporter": "^3.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "xunit-viewer": "^10.6.1"
  }
}
